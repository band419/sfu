        <mxCell id="A_ph" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fontFamily=Times New Roman;fontSize=11;fillColor=none;strokeColor=#666666;dashed=1;spacingLeft=6;" value="&lt;b&gt;Payne-Hanek&lt;/b&gt;&lt;hr&gt;p = |x| * (2/pi)&lt;br&gt;k = floor(p),  y = p - k&lt;br&gt;q = k mod 4&lt;br&gt;&lt;hr&gt;Only q[1:0] needed&lt;br&gt;(full k discarded)" vertex="1">
          <mxGeometry height="140" width="200" x="920" y="390" as="geometry" />
        </mxCell>
        <mxCell id="A_premap" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fontFamily=Times New Roman;fontSize=11;fillColor=none;strokeColor=#666666;dashed=1;spacingLeft=6;" value="&lt;b&gt;Pre-map Table&lt;/b&gt;&lt;hr&gt;SIN q=0,2 -&gt; t = y&lt;br&gt;SIN q=1,3 -&gt; t = 1-y&lt;br&gt;COS q=0,2 -&gt; t = 1-y&lt;br&gt;COS q=1,3 -&gt; t = y&lt;br&gt;&lt;hr&gt;=&gt; &lt;b&gt;sel = mode XOR q[0]&lt;/b&gt;" vertex="1">
          <mxGeometry height="160" width="200" x="920" y="750" as="geometry" />
        </mxCell>
        <mxCell id="A_sign" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fontFamily=Times New Roman;fontSize=11;fillColor=none;strokeColor=#666666;dashed=1;spacingLeft=6;" value="&lt;b&gt;Sign Table (|x|)&lt;/b&gt;&lt;hr&gt;SIN: sign_u = q[1]&lt;br&gt;COS: sign_u = q[1] XOR q[0]&lt;br&gt;&lt;hr&gt;&lt;b&gt;Final:&lt;/b&gt;&lt;br&gt;SIN -&gt; sign_u XOR sign_x&lt;br&gt;COS -&gt; sign_u" vertex="1">
          <mxGeometry height="140" width="210" x="920" y="1220" as="geometry" />
        </mxCell>
        <mxCell id="A_err" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fontFamily=Times New Roman;fontSize=11;fillColor=none;strokeColor=#666666;dashed=1;spacingLeft=6;" value="&lt;b&gt;Error Budget&lt;/b&gt;&lt;hr&gt;1. PH truncation: gK+g&lt;br&gt;2. HOTBM: minimax &lt;= 1 ulp&lt;br&gt;3. Inter-stage: g = 2 bits&lt;br&gt;4. Final: faithful rounding" vertex="1">
          <mxGeometry height="110" width="210" x="920" y="1400" as="geometry" />
