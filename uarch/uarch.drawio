        <mxCell id="A_fp16" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fontFamily=Times New Roman;fontSize=11;fillColor=none;strokeColor=#666666;dashed=1;spacingLeft=6;" value="&lt;b&gt;FP16 Parameters&lt;/b&gt;&lt;hr&gt;w_E = 5,  w_F = 10&lt;br&gt;E0 = 15&lt;br&gt;g = 2  (guard bits)&lt;br&gt;gK = 12 (Kahan guard)&lt;br&gt;W = 36 (window width)" vertex="1">
